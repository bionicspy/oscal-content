    "groups": [
      {
        "id": "uoft-prov-auict-scope",
        "title": "Scope and Applicability",
        "controls": [
          {
            "id": "uoft-prov-auict-scope-01",
            "title": "Applicability of ICT Appropriate Use",
            "links": [
              {
                "rel": "related",
                "href": "uoft-govcn-poit-dev-01"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "These guidelines apply to all University information and communication technologies, including hardware, software, networks, services, and personally owned devices that access University ICT resources."
              }
            ]
          }
        ]
      },
      {
        "id": "uoft-prov-auict-use",
        "title": "Appropriate and Fair Use",
        "controls": [
          {
            "id": "uoft-prov-auict-use-01",
            "title": "Mission-Aligned Use",
            "links": [
              {
                "rel": "implements",
                "href": "uoft-govcn-poit-use-01"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "University ICT resources are intended to be used primarily for University-related activities consistent with the institution’s mission."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-use-02",
            "title": "Reasonable Personal Use",
            "links": [
              {
                "rel": "implements",
                "href": "uoft-govcn-poit-use-01"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "A reasonable level of personal use is permitted provided that such use does not interfere with operations, violate law or policy, or consume excessive resources."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-use-03",
            "title": "Equitable Allocation of Resources",
            "parts": [
              {
                "name": "statement",
                "prose": "ICT resources are finite and may be subject to limits or rules established to ensure fair and equitable access for all eligible users."
              }
            ]
          }
        ]
      },
      {
        "id": "uoft-prov-auict-privacy",
        "title": "Privacy and Monitoring",
        "controls": [
          {
            "id": "uoft-prov-auict-privacy-01",
            "title": "Expectation of Privacy",
            "parts": [
              {
                "name": "statement",
                "prose": "Users should not have an expectation of complete privacy when using University ICT resources, which remain the property of the University."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-privacy-02",
            "title": "Right to Access Electronic Files",
            "links": [
              {
                "rel": "related",
                "href": "uoft-govcn-poit-gov-02"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "The University reserves the right to examine electronic files in circumstances including investigations, legal compliance, or urgent operational requirements."
              }
            ]
          }
        ]
      },
      {
        "id": "uoft-prov-auict-access",
        "title": "Authorization and Access Control",
        "controls": [
          {
            "id": "uoft-prov-auict-access-01",
            "title": "Authorized Access Only",
            "parts": [
              {
                "name": "statement",
                "prose": "Access to ICT resources may only be granted by authorized personnel, and access privileges may not be delegated or shared."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-access-02",
            "title": "Credential Protection",
            "parts": [
              {
                "name": "statement",
                "prose": "Users are responsible for safeguarding passwords and credentials and are accountable for actions performed under their identity."
              }
            ]
          }
        ]
      },
      {
        "id": "uoft-prov-auict-misuse",
        "title": "Inappropriate Use",
        "controls": [
          {
            "id": "uoft-prov-auict-misuse-01",
            "title": "Unlawful or Prohibited Activities",
            "links": [
              {
                "rel": "implements",
                "href": "uoft-govcn-poit-use-02"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "ICT resources must not be used for unlawful activities or for purposes that violate University policies, including harassment, discrimination, fraud, plagiarism, or unauthorized disclosure of information."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-misuse-02",
            "title": "Prohibited Content",
            "links": [
              {
                "rel": "implements",
                "href": "uoft-govcn-poit-use-02"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "The use of ICT resources to access, store, or distribute pornographic or otherwise unlawful material is prohibited."
              }
            ]
          },
          {
            "id": "uoft-prov-auict-misuse-03",
            "title": "Intellectual Property Violations",
            "links": [
              {
                "rel": "implements",
                "href": "uoft-govcn-poit-use-02"
              }
            ],
            "parts": [
              {
                "name": "statement",
                "prose": "Unauthorized copying, distribution, or use of copyrighted materials, software, or trademarks using ICT resources is prohibited."
              }
            ]
          }
        ]
      }
    ],
